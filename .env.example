# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Comma-separated list of allowed email addresses
# For shared expenses: add your partner's email here so they can log in with their own Google account
# Example: ALLOWED_EMAILS=you@example.com,partner@example.com
ALLOWED_EMAILS=you@example.com

# Cron secret — protects /api/cron/snapshot from unauthorized access
# Generate with: openssl rand -base64 32
CRON_SECRET=generate-with-openssl-rand-base64-32

# Override snapshot cron interval in minutes (default: 10)
# SNAPSHOT_INTERVAL=10

# Resend — transactional email for price alert notifications (https://resend.com)
# Create a free account, generate an API key, and optionally verify a custom domain.
# Without this key, alert triggers are still stored and shown in-app but no email is sent.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Enable Banking — open banking integration (https://enablebanking.com)
# Create an application at https://enablebanking.com/settings/applications
# and download the RSA private key.
# ENABLEBANKING_APP_ID=your-application-id
# ENABLEBANKING_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
